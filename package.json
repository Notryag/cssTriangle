{
  "private": true,
  "homepage": ".",
  "scripts": {
    "start": "vite",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "predeploy": "npm run build",
    "deploy": "gh-pages -d dist",
    "prettier": "prettier --write '**/*.{js,jsx,tsx,ts,less,md,json}'",
    "test": "echo \"No tests configured\"",
    "test:coverage": "echo \"No tests configured\""
  },
  "gitHooks": {
    "pre-commit": "lint-staged"
  },
  "lint-staged": {
    "*.{js,jsx,less,md,json}": [
      "prettier --write"
    ],
    "*.ts?(x)": [
      "prettier --parser=typescript --write"
    ]
  },
  "dependencies": {
    "antd": "^4.24.16",
    "gh-pages": "^3.2.3",
    "react": "17.x",
    "react-color": "^2.19.3",
    "react-dom": "17.x"
  },
  "devDependencies": {
    "@types/react": "^17.0.0",
    "@types/react-dom": "^17.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "lint-staged": "^10.0.7",
    "less": "^4.2.0",
    "prettier": "^2.2.0",
    "typescript": "^4.1.2",
    "vite": "^7.1.7",
    "yorkie": "^2.0.0"
  }
}
